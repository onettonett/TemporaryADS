# Store text files with LF (avoids CRLF warnings on macOS with core.autocrlf=input).
* text=auto eol=lf

# Data / binaries — do not apply line-ending conversion
*.dta binary
*.parquet binary
*.feather binary
*.pkl binary
*.pickle binary
*.zip binary
*.7z binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.xlsx binary
*.xls binary
*.dta filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
